generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Session {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model User {
  id        Int      @id // Telegram user ID
  username  String?
  firstName String
  createdAt DateTime @default(now())

  settings  UserSettings?
  ticktick  TickTickToken?
}

model WhitelistEntry {
  userId    Int      @id
  addedAt   DateTime @default(now())
}

model ScheduledTask {
  id           Int      @id @default(autoincrement())
  userId       Int
  ticktickId   String   @unique
  title        String
  dueDate      DateTime
  isAllDay     Boolean  @default(false)
  reminded9am  Boolean  @default(false)
  remindedHour Boolean  @default(false)
}

model WeeklyReport {
  id              Int      @id @default(autoincrement())
  userId          Int
  weekStart       DateTime // Monday 00:00
  weekEnd         DateTime // Sunday 23:59
  totalPlanned    Int
  totalCompleted  Int
  totalOverdue    Int
  onTimePercent   Int
  reportText      String   // Full formatted report snapshot
  createdAt       DateTime @default(now())
}

model UserSettings {
  id             Int    @id @default(autoincrement())
  userId         Int    @unique
  personalGoals  String @default("")
  careerGoals    String @default("")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TickTickToken {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique
  clientId     String
  clientSecret String
  accessToken  String
  refreshToken String @default("")
  expiresAt    DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
