generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Session {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model User {
  id        Int      @id // Telegram user ID
  username  String?
  firstName String
  createdAt DateTime @default(now())

  settings  UserSettings?
  ticktick  TickTickToken?
}

model WhitelistEntry {
  userId    Int      @id
  addedAt   DateTime @default(now())
}

model UserSettings {
  id             Int    @id @default(autoincrement())
  userId         Int    @unique
  personalGoals  String @default("")
  careerGoals    String @default("")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TickTickToken {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique
  clientId     String
  clientSecret String
  accessToken  String
  refreshToken String @default("")
  expiresAt    DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
