generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model Session {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model TelegramUser {
  id        Int      @id // Telegram user ID
  username  String?
  firstName String
  createdAt DateTime @default(now())

  settings UserSettings?
  ticktick TickTickToken?

  @@map("User")
}

model WhitelistEntry {
  userId Int      @id
  addedAt DateTime @default(now())
}

model ScheduledTask {
  id           Int      @id @default(autoincrement())
  userId       Int
  ticktickId   String   @unique
  title        String
  dueDate      DateTime
  isAllDay     Boolean  @default(false)
  reminded9am  Boolean  @default(false)
  remindedHour Boolean  @default(false)
}

model WeeklyReport {
  id             Int      @id @default(autoincrement())
  userId         Int
  weekStart      DateTime
  weekEnd        DateTime
  totalPlanned   Int
  totalCompleted Int
  totalOverdue   Int
  onTimePercent  Int
  reportText     String
  createdAt      DateTime @default(now())
}

model UserSettings {
  id            Int    @id @default(autoincrement())
  userId        Int    @unique
  personalGoals String @default("")
  careerGoals   String @default("")

  user TelegramUser @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TickTickToken {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique
  clientId     String
  clientSecret String
  accessToken  String
  refreshToken String   @default("")
  expiresAt    DateTime

  user TelegramUser @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Own task storage ────────────────────────────────────────────────────────

model User {
  id                 BigInt    @id
  username           String?
  timezone           String    @default("UTC+3")
  morning_brief_time String    @default("09:00")
  quiet_hours_from   String?
  quiet_hours_to     String?
  last_brief_sent_at DateTime?
  tasks              Task[]
  createdAt          DateTime  @default(now())

  @@map("BotUser")
}

model Task {
  id           String      @id @default(cuid())
  userId       BigInt
  user         User        @relation(fields: [userId], references: [id])

  title        String      @db.VarChar(200)
  category     Category
  duration_tag DurationTag
  status       Status      @default(ACTIVE)

  elo_score    Int         @default(1000)

  due_date     DateTime?
  due_time     DateTime?

  delegated_to         String?
  delegated_at         DateTime?
  remind_delegation_at DateTime?

  last_activity_at DateTime  @default(now())
  completed_at     DateTime?
  frozen_at        DateTime?
  archived_at      DateTime?

  createdAt DateTime @default(now())

  @@map("BotTask")
}

enum Category {
  CAREER
  PERSONAL
}

enum DurationTag {
  MIN_5
  MIN_30
  HOUR_1
  HOUR_2
  PROJECT
}

enum Status {
  ACTIVE
  FROZEN
  ARCHIVED
  DONE
  DELETED
}
