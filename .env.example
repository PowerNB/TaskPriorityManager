BOT_TOKEN=your_telegram_bot_token
# TICKTICK_CLIENT_ID and TICKTICK_CLIENT_SECRET are set per-user via /connect command in the bot
TICKTICK_REDIRECT_URI=http://localhost:3000/oauth/callback
DATABASE_URL="file:./dev.db"
LOG_LEVEL=info
NODE_ENV=development
# Path to claude CLI executable (e.g. C:\Users\username\AppData\Roaming\npm\claude.cmd)
CLAUDE_PATH=claude
