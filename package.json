{
  "name": "task-priority-manager-bot",
  "version": "1.0.0",
  "description": "Telegram bot for task management with TickTick integration",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "chcp 65001 && node dist/main.js",
    "dev": "chcp 65001 && tsc-watch --onSuccess \"node dist/main.js\"",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push"
  },
  "dependencies": {
    "@grammyjs/conversations": "^2.0.1",
    "@grammyjs/menu": "^1.3.0",
    "@grammyjs/runner": "^2.0.3",
    "@grammyjs/storage-prisma": "^2.5.1",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/form-data": "^2.2.1",
    "@types/node-cron": "^3.0.11",
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.5",
    "grammy": "^1.31.0",
    "groq-sdk": "^1.1.2",
    "node-cron": "^4.2.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@prisma/client": "^5.22.0",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "eslint": "^9.17.0",
    "prisma": "^5.22.0",
    "tsc-watch": "^6.2.1",
    "typescript": "^5.7.2"
  }
}
